# ICM backend base URL (without trailing slash)
# Injected automatically when running inside Docker compose (ADR-0006)
ICM_BASE_URL=http://localhost:8085/idm/api

# Keycloak token endpoint for the service account (BFF client-credentials, ADR-0005)
KC_TOKEN_URL=http://localhost:8180/realms/intelligent-content-management/protocol/openid-connect/token
KC_CLIENT_ID=icm-bff
KC_CLIENT_SECRET=your-client-secret-here

# APP_URL: The URL where this app is hosted (used for self-referential links / OAuth callbacks)
APP_URL=http://localhost:3000
